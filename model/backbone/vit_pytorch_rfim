class LPM(LPMTransReID):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        num_patches = self.patch_embed.num_patches
        self.in_chans = kwargs.get("in_chans") or 3
        self.img_size = kwargs.get("img_size")
        self.stride_size = kwargs.get("stride_size")

        print("templates shape: ", self.get_templates_shape())
        self.templates = nn.Parameter(torch.zeros(self.get_templates_shape()))
        self.templates_inited = False
        self.pos_embed = nn.Parameter(
            torch.zeros(1, num_patches * 2 + 1, kwargs.get("embed_dim"))
        )
        trunc_normal_(self.pos_embed, std=0.02)

    @torch.jit.ignore
    def no_weight_decay(self):
        return {"pos_embed", "cls_token", "templates"}

    def forward_features(self, x, camera_id, view_id, get_attn_weights=False):
        B = x.shape[0]
        x = self.patch_embed(x)

        cls_tokens = self.cls_token.expand(
            B, -1, -1
        )  # stole cls_tokens impl from Phil Wang, thanks

        # ----template opration----
        # templates init
        if not self.templates_inited and self.training:
            self.init_templates(x[:1])

        # get templates
        if self.cam_num > 0 and self.view_num > 0:
            templates = self.templates[camera_id * self.view_num + view_id]
        elif self.cam_num > 0:
            templates = self.templates[camera_id]
        elif self.view_num > 0:
            templates = self.templates[view_id]
        else:
            templates = self.templates.expand(B, -1, -1)

        x = torch.cat((cls_tokens, x, templates), dim=1)
        # ----template opration end----

        if self.cam_num > 0 and self.view_num > 0:
            x = (
                x
                + self.pos_embed
                + self.sie_xishu * self.sie_embed[camera_id * self.view_num + view_id]
            )
        elif self.cam_num > 0:
            x = x + self.pos_embed + self.sie_xishu * self.sie_embed[camera_id]
        elif self.view_num > 0:
            x = x + self.pos_embed + self.sie_xishu * self.sie_embed[view_id]
        else:
            x = x + self.pos_embed

        x = self.pos_drop(x)

        if self.local_feature:
            attn_weights = []
            for blk in self.blocks[:-1]:
                x, weights = blk(x, get_attn_weights=True)
                attn_weights.append(weights)
            if get_attn_weights:
                return x, attn_weights
            return x
        else:
            attn_weights = []
            for blk in self.blocks:
                x, weights = blk(x, get_attn_weights=True)
                attn_weights.append(weights)
            x = self.norm(x)
            if get_attn_weights:
                return x, attn_weights
            return x[:, 0]

    def load_param(self, model_path):
        param_dict = torch.load(model_path, map_location="cpu")
        if "model" in param_dict:
            param_dict = param_dict["model"]
        if "state_dict" in param_dict:
            param_dict = param_dict["state_dict"]
        for k, v in param_dict.items():
            if "head" in k or "dist" in k:
                continue
            if "patch_embed.proj.weight" in k and len(v.shape) < 4:
                # For old models that I trained prior to conv based patchification
                O, I, H, W = self.patch_embed.proj.weight.shape
                v = v.reshape(O, -1, H, W)
            elif k == "pos_embed" and v.shape != self.pos_embed.shape:
                # To resize pos embedding when using model at different size from pretrained weights
                if "distilled" in model_path:
                    print("distill need to choose right cls token in the pth")
                    v = torch.cat([v[:, 0:1], v[:, 2:]], dim=1)
                v = resize_pos_embed(
                    v, self.pos_embed, self.patch_embed.num_y, self.patch_embed.num_x
                )
            try:
                if k == "pos_embed":
                    # TAT
                    self.state_dict()["pos_embed"].copy_(
                        torch.cat(
                            (
                                v[:, :1, :],
                                v[:, 1:, :],
                                # v[:, 1:, :],  # bad one
                                torch.randn_like(v[:, 1:, :]),  # good one
                            ),
                            1,
                        )
                    )
                else:
                    self.state_dict()[k].copy_(v)
            except Exception:
                print("===========================ERROR=========================")
                print(
                    "shape do not match in k :{}: param_dict{} vs self.state_dict(){}".format(
                        k, v.shape, self.state_dict()[k].shape
                    )
                )

    def init_templates(self, init_img_emb):
        init_strategy = "conved_image"
        if init_strategy == "conved_image":
            if self.cam_num > 0 and self.view_num > 0:
                self.templates = nn.Parameter(
                    init_img_emb.repeat(self.cam_num * self.view_num, 1, 1)
                )
            elif self.cam_num > 0:
                self.templates = nn.Parameter(init_img_emb.repeat(self.cam_num, 1, 1))
            elif self.view_num > 0:
                self.templates = nn.Parameter(init_img_emb.repeat(self.view_num, 1, 1))
            else:
                self.templates = nn.Parameter(init_img_emb)
        elif init_strategy == "full_zero":
            pass
            # self.templates = nn.Parameter(torch.zeros(self.get_templates_shape())).to(init_img_emb.device)
        elif init_strategy == "trunc_normal":
            trunc_normal_(self.templates, std=0.02)

        self.templates_inited = True

    def get_templates_shape(self):
        #根据相机数量(cam_num)和视角数量(view_num)来确定模板张量的第一个维度b。
        if self.cam_num > 0 and self.view_num > 0:
            b = self.cam_num * self.view_num
        elif self.cam_num > 0:
            b = self.cam_num
        elif self.view_num > 0:
            b = self.view_num
        else:
            b = 1

        #从patch_embed模块中获取补丁嵌入的宽度(num_x)和高度(num_y)。
        num_x = self.patch_embed.num_x
        num_y = self.patch_embed.num_y
        return b, num_x * num_y, self.embed_dim
        #返回一个包含三个元素的元组，表示模板张量的形状。

